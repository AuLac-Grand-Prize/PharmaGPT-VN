APP_ENV=development
APP_PORT=8003
LOG_LEVEL=INFO

# --- LLM ---
BASE_MODEL=meta-llama/Llama-3.1-8B-Instruct
ADAPTER_PATH=models/pharmagpt_vn_lora_v1
DEVICE=cuda
DTYPE=bfloat16
MAX_MODEL_LEN=8192
GPU_MEMORY_UTILIZATION=0.85

# --- Embedding model ---
EMBEDDING_MODEL=BAAI/bge-m3

# --- Qdrant (vector store) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=vn_pharma_corpus

# --- Redis (response cache + rate limit) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
INTERNAL_API_TOKEN=replace-with-strong-random-secret

# --- Guardrails ---
ENFORCE_CITATIONS_FOR_CLINICAL=true
PII_REDACTION_ENABLED=true
MEDICAL_DISCLAIMER_ENABLED=true

# --- Sampling defaults ---
DEFAULT_TEMPERATURE=0.2
DEFAULT_TOP_P=0.9
DEFAULT_MAX_TOKENS=512
