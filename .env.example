APP_ENV=development
APP_PORT=8003
LOG_LEVEL=INFO

# --- LLM (OpenAI-compatible remote API) ---
OPENAI_BASE_URL=http://your-llm-endpoint/v1
OPENAI_API_KEY=replace-with-your-api-key
LLM_MODEL_MAIN=cx/gpt-5.5

# --- Embedding model ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDER_DEVICE=cpu

# --- Reranker (OpenRouter Cohere) ---
OPENROUTER_API_KEY=replace-with-your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
RERANKER_MODEL=cohere/rerank-v3.5

# --- Qdrant (vector store) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=vn_pharma_corpus

# --- Redis (response cache + rate limit) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
INTERNAL_API_TOKEN=replace-with-strong-random-secret

# --- Guardrails ---
ENFORCE_CITATIONS_FOR_CLINICAL=true
PII_REDACTION_ENABLED=true
MEDICAL_DISCLAIMER_ENABLED=true

# --- Sampling defaults ---
DEFAULT_TEMPERATURE=0.2
DEFAULT_TOP_P=0.9
DEFAULT_MAX_TOKENS=512

# --- Query Understanding (3-branch parallel: rewrite + decompose + HyDE) ---
QU_REWRITE_N=3
QU_DECOMPOSE_MAX=4
QU_HYDE_ENABLED=true
QU_HYDE_MAX_TOKENS=256
QU_PER_BRANCH_TOP_K=30
QU_RRF_K=60
